# Database Configuration (Auto-filled by Render)
DATABASE_URL=mysql://user:password@host:3306/garapexpress_db

# Twilio SMS Configuration
# Get these from https://www.twilio.com/console
TWILIO_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM=+1234567890

# Email Configuration (Gmail SMTP)
# Use App Password if you have 2FA enabled: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL for password reset links and CORS
FRONTEND_URL=https://your-mobile-app-url.com

# Node environment
NODE_ENV=production
PORT=3000
